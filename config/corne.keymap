#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/*  Original
/ {
        keymap {
                compatible = "zmk,keymap";

                default_layer {
// -----------------------------------------------------------------------------------------
// |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
// | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
// | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
//                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |
                        bindings = <
   &kp TAB   &kp Q &kp W &kp E &kp R &kp T   &kp Y &kp U  &kp I     &kp O   &kp P    &kp BSPC
   &kp LCTRL &kp A &kp S &kp D &kp F &kp G   &kp H &kp J  &kp K     &kp L   &kp SEMI &kp SQT
   &kp LSHFT &kp Z &kp X &kp C &kp V &kp B   &kp N &kp M  &kp COMMA &kp DOT &kp FSLH &kp ESC
                  &kp LGUI &mo 1 &kp SPACE   &kp RET &mo 2 &kp RALT
                        >;
                };
                lower_layer {
// -----------------------------------------------------------------------------------------
// |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BSPC |
// | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
// | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
//                    | GUI |     | SPC |   | ENT |     | ALT |
                        bindings = <
   &kp TAB    &kp N1       &kp N2       &kp N3       &kp N4       &kp N5         &kp N6   &kp N7   &kp N8 &kp N9    &kp N0 &kp BSPC
   &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4   &kp LEFT &kp DOWN &kp UP &kp RIGHT &trans &trans
   &kp LSHFT  &trans       &trans       &trans       &trans       &trans         &trans   &trans   &trans &trans    &trans &trans
                                    &kp LGUI     &trans       &kp SPACE      &kp RET  &trans   &kp RALT
                        >;
                };

                raise_layer {
// -----------------------------------------------------------------------------------------
// |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BSPC |
// | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
// | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
//                    | GUI |     | SPC |   | ENT |     | ALT |
                        bindings = <
   &kp  TAB  &kp EXCL &kp AT &kp HASH &kp DLLR &kp PRCNT   &kp CARET &kp AMPS  &kp ASTRK &kp LPAR &kp RPAR &kp BSPC
   &kp LCTRL &trans   &trans &trans   &trans   &trans      &kp MINUS &kp EQUAL &kp LBKT  &kp RBKT &kp BSLH &kp GRAVE
   &kp LSHFT &trans   &trans &trans   &trans   &trans      &kp UNDER &kp PLUS  &kp LBRC  &kp RBRC &kp PIPE &kp TILDE
                             &kp LGUI &trans   &kp SPACE   &kp RET   &trans    &kp RALT
                        >;
                };
        };
};
*/


// 2026-05-27 Greenfield design:
// Layer 0:
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
//|||||||    Left Alt    |       Q       |       W       |       E       |       R       |       T       |||||||||||||||       Y       |       U       |       I       |       O       |       P       |   Left GUI    |
//|||||||  Left Control  |       A       |       S       |       D       |       F       |       G       |||||||||||||||       H       |       J       |       K       |       L       |       ;       |       '       |
//|||||||   Left Shift   |       Z       |       X       |       C       |       V       |       B       |||||||||||||||       N       |       M       |       ,       |       .       |       /       |  Right Shift  |
//||||||||||||||||||||||||||||||||||||||||||||||||||||||||     Delete    |   Backspace   |    Layer 1    |||||||||||||||    Layer 2    |     Space     |    Return     |||||||||||||||||||||||||||||||||||||||||||||||||
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

// Layer 1:
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
//|||||||   (Left Alt)   |       1       |       2       |       3       |       4       |       5       |||||||||||||||       6       |       7       |       8       |       9       |       0       |  (Left GUI)   |
//||||||| (Left Control) |   Left GUI    |   Left Alt    |  Left Control |  Left Shift   |               |||||||||||||||     Left      |     Down      |       Up      |     Right     |    Escape     |               |
//|||||||  (Left Shift)  |               |  shift-delete |  ctrl-insert  | shift-insert  |               |||||||||||||||     Home      |   Page Down   |    Page Up    |      End      |  Context Menu | (Right Shift) |
//||||||||||||||||||||||||||||||||||||||||||||||||||||||||               |               |   (pressed)   |||||||||||||||    Layer 3    |               |               |||||||||||||||||||||||||||||||||||||||||||||||||
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

// Layer 2:
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
//|||||||   (Left Alt)   |       !       |       @       |       #       |       $       |       %       |||||||||||||||       ^       |       &       |       *       |       (       |       )       |  (Left GUI)   |
//||||||| (Left Control) |       \       |       -       |       =       |       `       |    Escape     |||||||||||||||  Right Shift  | Right Control |   Right Alt   |   Right GUI   |               |               |
//|||||||  (Left Shift)  |     Pipe      |       _       |       +       |       ~       |  Context Menu |||||||||||||||     Home      |   Page Down   |    Page Up    |      End      |               | (Right Shift) |
//||||||||||||||||||||||||||||||||||||||||||||||||||||||||               |               |    Layer 3    |||||||||||||||   (pressed)   |               |               |||||||||||||||||||||||||||||||||||||||||||||||||
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

// Layer 3:
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
//|||||||       F11      |      F1       |      F2       |      F3       |      F4       |      F5       |||||||||||||||      F6       |      F7       |      F8       |      F9       |      F10      |      F12      |
//|||||||   Volume Mute  |  Volume Down  |   Volume Up   |               |  Bright Down  |   Bright Up   ||||||||||||||| L Control Stk |  L Shift Stk  | L Super Stk   | L Alt Sticky  |               |               |
//||||||| Bluetooth Clr  |  Bluetooth 1  |  Bluetooth 2  |  Bluetooth 3  |  Bluetooth 4  |  Bluetooth 5  |||||||||||||||    Insert     |   PrintScr    |               |               |               |               |
//||||||||||||||||||||||||||||||||||||||||||||||||||||||||               |               |   (pressed)   |||||||||||||||   (pressed)   |               |               |||||||||||||||||||||||||||||||||||||||||||||||||
//-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
/ {
        keymap {
                compatible = "zmk,keymap";

                default_layer {
// -----------------------------------------------------------------------------------------
// |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
// | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
// | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
//                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |
                        bindings = <
   &kp LALT  &kp Q &kp W &kp E &kp R &kp T   &kp Y &kp U  &kp I     &kp O   &kp P    &kp BSPC
   &kp LCTRL &kp A &kp S &kp D &kp F &kp G   &kp H &kp J  &kp K     &kp L   &kp SEMI &kp SQT
   &kp LSHFT &kp Z &kp X &kp C &kp V &kp B   &kp N &kp M  &kp COMMA &kp DOT &kp FSLH &kp ESC
                  &kp DEL &kp BSPC &mo 1   &mo 2 &kp SPAC &kp RET
                        >;
                };
                lower_layer {
                        bindings = <
/*#####*/ &trans             /*#####*/ &kp    N1          /*#####*/ &kp    N2          /*#####*/ &kp N3             /*#####*/ &kp N4             /*#####*/ &kp N5             /*### ###*/ &kp N6             /*#####*/ &kp N7             /*#####*/ &kp N8             /*#####*/ &kp N9             /*#####*/ &kp N0             /*#####*/ &trans             /*#####*/
/*#####*/ &trans             /*#####*/ &kp    LGUI        /*#####*/ &kp    LALT        /*#####*/ &kp LCTRL          /*#####*/ &kp LSHFT          /*#####*/ &none              /*### ###*/ &kp LEFT           /*#####*/ &kp DOWN           /*#####*/ &kp UP             /*#####*/ &kp RIGHT          /*#####*/ &kp ESCAPE         /*#####*/ &none              /*#####*/
/*#####*/ &trans             /*#####*/ &none              /*#####*/ &kp    K_CUT       /*#####*/ &kp K_COPY         /*#####*/ &kp K_PASTE        /*#####*/ &none              /*### ###*/ &kp HOME           /*#####*/ &kp PG_UP          /*#####*/ &kp PG_DN          /*#####*/ &kp END            /*#####*/ &kp K_CONTEXT_MENU /*#####*/ &trans             /*#####*/
/*############################################################################################*/ &trans             /*#####*/ &trans             /*#####*/ &trans             /*### ###*/ &mo 3              /*#####*/ &trans             /*#####*/ &trans             /*############################################################################################*/
                        >;
                };

                raise_layer {
                        bindings = <
/*#####*/ &trans             /*#####*/ &kp    EXCL        /*#####*/ &kp    AT          /*#####*/ &kp HASH           /*#####*/ &kp DLLR           /*#####*/ &kp PRCNT          /*### ###*/ &kp CARET          /*#####*/ &kp AMPS           /*#####*/ &kp ASTRK          /*#####*/ &kp LPAR           /*#####*/ &kp RPAR           /*#####*/ &trans             /*#####*/
/*#####*/ &trans             /*#####*/ &kp    BACKSLASH   /*#####*/ &kp MINUS          /*#####*/ &kp EQUAL          /*#####*/ &kp GRAVE          /*#####*/ &kp ESCAPE         /*### ###*/ &kp RSHFT          /*#####*/ &kp RCTRL          /*#####*/ &kp RALT           /*#####*/ &kp RGUI           /*#####*/ &trans             /*#####*/ &trans             /*#####*/
/*#####*/ &trans             /*#####*/ &kp    PIPE        /*#####*/ &kp UNDERSCORE     /*#####*/ &kp PLUS           /*#####*/ &kp TILDE          /*#####*/ &kp K_CONTEXT_MENU /*### ###*/ &kp HOME           /*#####*/ &kp PG_UP          /*#####*/ &kp PG_DN          /*#####*/ &kp END            /*#####*/ &trans             /*#####*/ &trans             /*#####*/
/*############################################################################################*/ &trans             /*#####*/ &trans             /*#####*/ &mo 3              /*### ###*/ &trans             /*#####*/ &trans             /*#####*/ &trans             /*############################################################################################*/
                        >;
                };

                special_layer {
                        bindings = <
/*#####*/ &kp F11            /*#####*/ &kp    F1          /*#####*/ &kp    F2          /*#####*/ &kp F3             /*#####*/ &kp F4             /*#####*/ &kp F5             /*### ###*/ &kp F6             /*#####*/ &kp F7             /*#####*/ &kp F8             /*#####*/ &kp F9             /*#####*/ &kp F10            /*#####*/ &kp F12            /*#####*/
/*#####*/ &kp K_MUTE         /*#####*/ &kp K_VOL_DOWN     /*#####*/ &kp K_VOL_UP       /*#####*/ &none              /*#####*/ &kp C BRI_DOWN     /*#####*/ &kp C BRI_UP       /*### ###*/ &sk LCTRL          /*#####*/ &sk LSHFT          /*#####*/ &sk LGUI           /*#####*/ &sk LALT           /*#####*/ &none              /*#####*/ &none              /*#####*/
/*#####*/ &bt BT_CLR         /*#####*/ &bt BT_SEL 0       /*#####*/ &bt BT_SEL 1       /*#####*/ &bt BT_SEL 2       /*#####*/ &bt BT_SEL 3       /*#####*/ &bt BT_SEL 4       /*### ###*/ &kp INSERT         /*#####*/ &kp PRINTSCREEN    /*#####*/ &none              /*#####*/ &none              /*#####*/ &none              /*#####*/ &none              /*#####*/
/*############################################################################################*/ &trans             /*#####*/ &trans             /*#####*/ &trans             /*### ###*/ &trans             /*#####*/ &trans             /*#####*/ &trans             /*############################################################################################*/
                        >;
                };
        };
};
